    "@stripe/stripe-js": "^8.9.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "framer-motion": "^12.35.0",
