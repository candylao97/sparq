generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  PROVIDER
  BOTH
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  DECLINED
  CANCELLED_BY_CUSTOMER
  CANCELLED_BY_PROVIDER
  REFUNDED
  EXPIRED
  DISPUTED
  NO_SHOW
  RESCHEDULE_REQUESTED
}

enum PaymentStatus {
  NONE
  AUTH_PENDING
  AUTHORISED
  CAPTURED
  AUTH_RELEASED
  REFUNDED
  PARTIAL_REFUND
  FAILED
}

enum ServiceLocation {
  AT_HOME
  STUDIO
  BOTH
}

enum ServiceCategory {
  NAILS
  LASHES
  HAIR
  MAKEUP
  BROWS
  WAXING
  MASSAGE
  FACIALS
  TUTORING
  OTHER
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  UNDER_REVIEW
  BANNED
}

enum RefundStatus {
  NONE
  REQUESTED
  APPROVED
  PROCESSED
  DENIED
}


enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUND
  RESOLVED_NO_REFUND
  CLOSED
}

enum KYCStatus {
  PENDING
  REQUIRES_ACTION
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  NEW_BOOKING
  BOOKING_ACCEPTED
  BOOKING_DECLINED
  BOOKING_COMPLETED
  BOOKING_CANCELLED
  NEW_MESSAGE
  NEW_REVIEW
  PAYMENT_RECEIVED
  PAYOUT_SENT
  BOOKING_EXPIRED
  BOOKING_DISPUTED
  REVIEW_REMINDER
  RESCHEDULE_REQUESTED
  REVIEW_REPLY
  DISPUTE_RESOLVED
  REFUND_PROCESSED
  GENERAL
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password          String?
  passwordChangedAt DateTime?
  role              UserRole  @default(CUSTOMER)
  phone             String?
  accountStatus     AccountStatus    @default(ACTIVE)
  // P0-1: Persisted notification preference map (email, SMS, push channels)
  notificationPreferences Json?
  // FIND-4: ToS consent capture. Populated by POST /api/auth/register and the
  // /register/provider path. Null for users created before the field existed
  // — a future re-prompt flow will backfill on next login. Version string
  // follows legal's scheme (currently the placeholder `v1-placeholder`).
  termsAcceptedAt   DateTime?
  termsVersion      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  providerProfile    ProviderProfile?
  customerProfile    CustomerProfile?
  bookingsAsCustomer Booking[]        @relation("CustomerBookings")
  bookingsAsProvider Booking[]        @relation("ProviderBookings")
  sentMessages       Message[]
  notifications      Notification[]
  reviews            Review[]         @relation("CustomerReviews")
  adminNotes         AdminNote[]      @relation("AdminNotes")
  leakageFlags       ContactLeakageFlag[]
  auditLogs          AuditLog[] @relation("AdminAuditLogs")
  waitlistAsCustomer WaitlistEntry[] @relation("CustomerWaitlist")
  waitlistAsProvider WaitlistEntry[] @relation("ProviderWaitlist")
  providerPayouts    Payout[]        @relation("ProviderPayouts")
  promoCodes         PromoCode[]
  promoCodeUsages    PromoCodeUsage[]
  referralsSent      Referral[] @relation("ReferrerReferrals")
  referralsReceived  Referral[] @relation("ReferredReferrals")
}

model CustomerProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  savedProviders       String[]
  // Generic Stripe customer pointer. Vestigial today (premium membership
  // removed); retained for the deferred Item 6b tip-on-review-page work
  // which needs a saved payment method to charge tip off-session.
  stripeCustomerId     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProviderProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  tagline          String?
  serviceRadius    Int?             @default(10)
  studioAddress    String?
  suburb           String?
  city             String           @default("Sydney")
  state            String           @default("NSW")
  latitude         Float?
  longitude        Float?
  offerAtHome      Boolean          @default(true)
  offerAtStudio    Boolean          @default(false)
  stripeAccountId        String?
  stripeChargesEnabled   Boolean @default(false)
  stripePayoutsEnabled   Boolean @default(false)
  stripeDetailsSubmitted Boolean @default(false)
  isVerified       Boolean          @default(false)
  backgroundCheck  Boolean          @default(false)
  yearsExperience  Int?
  languages        String[]
  accountStatus    AccountStatus    @default(ACTIVE)
  suspendReason    String?          @db.Text
  suspendedAt      DateTime?
  responseTimeHours       Float            @default(24)
  completionRate          Float            @default(100)
  totalEarnings           Float            @default(0)
  // MH-6: Cancellation strike system — tracks consecutive provider cancellations for account health
  cancellationCount       Int              @default(0)
  cancellationCountResetAt DateTime?
  cancellationPolicy      String?          @db.Text
  cancellationPolicyType  String           @default("MODERATE")
  isFeatured              Boolean          @default(false)
  featuredUntil           DateTime?
  icalToken               String?          @unique
  icalTokenExpiresAt      DateTime?
  timezone                String           @default("Australia/Sydney")
  profileViews            Int              @default(0)
  createdAt               DateTime         @default(now())
  aiSummary               String?          @db.Text
  // P1-2: Tracks when the AI summary was last generated — used as the 24h cooldown check.
  // Separating from updatedAt avoids resetting the cooldown on unrelated profile updates.
  aiSummaryUpdatedAt      DateTime?
  updatedAt               DateTime         @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  services     Service[]
  availability Availability[]
  portfolio    PortfolioPhoto[]
  verification Verification?
  scoreFactors ScoreFactors?
  kycRecord    KYCRecord?
}

model ScoreFactors {
  id               String          @id @default(cuid())
  providerProfileId String         @unique
  reviewScore      Float           @default(0)
  completionScore  Float           @default(0)
  responseScore    Float           @default(0)
  consistencyScore Float           @default(0)
  verificationScore Float          @default(0)
  updatedAt        DateTime        @updatedAt

  provider ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
}

model Service {
  id            String          @id @default(cuid())
  providerProfileId String
  title         String
  category      ServiceCategory
  description   String?         @db.Text
  price         Float
  duration      Int
  locationTypes ServiceLocation @default(BOTH)
  maxGuests     Int?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  instantBook   Boolean   @default(false)

  provider  ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  addons    ServiceAddon[]
  isDeleted Boolean         @default(false)

  @@index([providerProfileId])
  @@index([isDeleted])
}

model Availability {
  id         String   @id @default(cuid())
  providerProfileId String
  date       DateTime @db.Date
  timeSlots  String[]
  isBlocked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  // P1-7: Optimistic lock field — used by availability update endpoint to detect concurrent writes
  updatedAt  DateTime @updatedAt

  provider ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([providerProfileId, date])
}

model Booking {
  id              String          @id @default(cuid())
  customerId      String
  providerUserId  String
  serviceId       String
  date            DateTime
  time            String
  locationType    ServiceLocation
  address         String?
  guestCount      Int?
  status          BookingStatus   @default(PENDING)
  totalPrice      Float
  platformFee     Float
  commissionRate  Float
  tipAmount       Float           @default(0)
  stripePaymentId String?
  paymentStatus   PaymentStatus   @default(NONE)
  giftVoucherCode String?
  notes           String?         @db.Text
  refundStatus    RefundStatus    @default(NONE)
  refundAmount    Float?
  refundReason    String?         @db.Text
  refundedAt       DateTime?
  acceptDeadline       DateTime?
  completedAt          DateTime?
  disputeDeadline      DateTime?
  rescheduleDate       DateTime?
  rescheduleTime       String?
  rescheduleReason     String?      @db.Text
  rescheduleRequestedAt    DateTime?
  paymentExpiryWarnedAt    DateTime?
  reminderSentAt           DateTime?
  createdAt                DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  customer User      @relation("CustomerBookings", fields: [customerId], references: [id])
  provider User      @relation("ProviderBookings", fields: [providerUserId], references: [id])
  service  Service   @relation(fields: [serviceId], references: [id])
  review          Review?
  messages        Message[]
  payout          Payout?
  statusHistory   BookingStatusHistory[]
  dispute         Dispute?
  promoCodeUsage  PromoCodeUsage?

  @@index([customerId])
  @@index([providerUserId])
  @@index([status])
}

model Review {
  id               String   @id @default(cuid())
  bookingId        String   @unique
  customerId       String
  rating           Int
  text             String?  @db.Text
  aiSummary        String?  @db.Text
  providerResponse String?  @db.Text
  isVisible        Boolean  @default(true)
  isFlagged        Boolean  @default(false)
  isVerifiedPurchase Boolean @default(true)
  flagReason       String?  @db.Text
  moderatedAt      DateTime?
  moderatedBy      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  booking  Booking @relation(fields: [bookingId], references: [id])
  customer User    @relation("CustomerReviews", fields: [customerId], references: [id])
}

model PortfolioPhoto {
  id         String   @id @default(cuid())
  providerProfileId String
  url        String
  publicId   String?
  caption    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  provider ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(cuid())
  bookingId String
  senderId  String
  text      String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  sender  User    @relation(fields: [senderId], references: [id])

  @@index([bookingId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id                          String             @id @default(cuid())
  providerProfileId           String             @unique
  stripeVerificationSessionId String?
  status                      VerificationStatus @default(PENDING)
  backgroundCheckStatus       VerificationStatus @default(PENDING)
  adminNotes                  String?
  submittedAt                 DateTime           @default(now())
  reviewedAt                  DateTime?

  provider ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
}

model AdminNote {
  id        String   @id @default(cuid())
  adminId   String
  subject   String
  body      String   @db.Text
  category  String   @default("general")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admin User @relation("AdminNotes", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([category])
}

model Suburb {
  id        String   @id @default(cuid())
  name      String
  postcode  String
  state     String   @default("NSW")
  city      String   @default("Sydney")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([name, postcode])
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
  label String?
  group String @default("general")

  @@index([group])
}

model GiftVoucher {
  id               String   @id @default(cuid())
  code             String   @unique
  amount           Float
  usedAmount       Float    @default(0)
  remainingBalance Float?
  issuedBy         String
  usedBy           String?
  isRedeemed       Boolean  @default(false)
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  recipientEmail   String?
  // M-3: Reservation hold — prevents double-spend race conditions during concurrent checkout.
  // A voucher held by another user within the last 15 minutes will be temporarily blocked.
  heldByUserId     String?
  heldAt           DateTime?
}

model ContactLeakageFlag {
  id         String    @id @default(cuid())
  messageId  String?
  reviewId   String?
  bookingId  String?
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  flagType   String
  snippet    String    @db.Text
  resolved   Boolean   @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Payout {
  id               String       @id @default(cuid())
  bookingId        String       @unique
  // FIND-12: FK to User — previously `providerId: String` with no @relation,
  // which is what made FIND-2 (payout history empty) and FIND-3 (notification
  // FK violation on cron) possible undetected. Renamed + FK'd to User so the
  // `Notification.userId: payout.providerUserId` write in the cron is correct
  // by construction.
  providerUserId   String
  amount           Float
  platformFee      Float
  stripeTransferId String?
  status           PayoutStatus @default(SCHEDULED)
  scheduledAt      DateTime
  processedAt      DateTime?
  failedAt         DateTime?
  failureReason    String?
  // P1-B: For negative (penalty) payout records, tracks when the penalty expires (90 days from creation).
  // Expired penalties are excluded from deductions during payout processing.
  penaltyExpiresAt DateTime?
  createdAt        DateTime     @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  providerUser User @relation("ProviderPayouts", fields: [providerUserId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([scheduledAt])
  @@index([providerUserId])
}

model BookingStatusHistory {
  id         String   @id @default(cuid())
  bookingId  String
  fromStatus String
  toStatus   String
  changedBy  String
  reason     String?
  createdAt  DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Dispute {
  id          String        @id @default(cuid())
  bookingId   String        @unique
  customerId  String
  reason      String        @db.Text
  evidence    String?       @db.Text
  status      DisputeStatus @default(OPEN)
  resolution  String?       @db.Text
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
}

model WaitlistEntry {
  id         String   @id @default(cuid())
  customerId String
  providerUserId String
  serviceId  String?
  date       DateTime
  notified   Boolean  @default(false)
  sequence   Int      @default(autoincrement())
  createdAt  DateTime @default(now())

  customer User @relation("CustomerWaitlist", fields: [customerId], references: [id], onDelete: Cascade)
  provider User @relation("ProviderWaitlist", fields: [providerUserId], references: [id], onDelete: Cascade)

  @@index([providerUserId, date])
  @@index([customerId])
}

model ServiceAddon {
  id         String  @id @default(cuid())
  serviceId  String
  name       String
  price      Float
  duration   Int     @default(0)
  isActive   Boolean @default(true)
  usageCount Int     @default(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model KYCRecord {
  id              String    @id @default(cuid())
  providerProfileId String  @unique
  status          KYCStatus @default(PENDING)
  riskLevel       RiskLevel @default(LOW)
  riskSignals     Json?
  stripeStatus    String?
  chargesEnabled  Boolean   @default(false)
  payoutsEnabled  Boolean   @default(false)
  requirementsDue Json?
  adminNotes      String?   @db.Text
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectedReason  String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  provider ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([riskLevel])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String?
  details    Json?
  reason     String?
  createdAt  DateTime @default(now())

  actor User @relation("AdminAuditLogs", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  description    String?
  discountType   String    @default("PERCENT")   // PERCENT | FIXED
  discountValue  Float                            // e.g. 15 for 15% or 10 for $10
  minOrderAmount Float     @default(0)
  maxUses        Int?                             // null = unlimited
  currentUses    Int       @default(0)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  source         String?                          // e.g. 'instagram_jan', 'referral', 'partnership_xyz'
  campaign       String?                          // e.g. 'summer_launch_2026'
  createdById    String?
  // M-6: Budget cap — maximum total discount amount this code can issue across all redemptions
  budgetCap               Float?   // null = no cap
  totalDiscountIssued     Float    @default(0)   // running total of discounts issued
  createdBy      User?     @relation(fields: [createdById], references: [id])
  usages         PromoCodeUsage[]
}

model PromoCodeUsage {
  id          String    @id @default(cuid())
  promoCodeId String
  userId      String
  bookingId   String?   @unique
  usedAt      DateTime  @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  booking   Booking?  @relation(fields: [bookingId], references: [id])

  @@unique([promoCodeId, userId])
  @@index([userId])
}

// FIND-6 — Email suppression list for unsubscribe compliance
// (AU Spam Act 2003 requires a functional unsubscribe on every
// commercial electronic message).
//
// Adding an email here skips all subsequent NON-transactional sends
// to that address. Transactional emails (booking_confirmation,
// password_reset, payout_initiated, account_verification, etc.) are
// still delivered — they're not "commercial electronic messages"
// under s.5 of the Act.
//
// `reason` is free-text but conventionally one of:
//   'user_unsubscribe' | 'bounce' | 'complaint' | 'admin_block'
// `sourceCampaign` lets us attribute unsubscribes back to a specific
// send for future campaign-quality reporting.
model Suppression {
  email           String   @id
  suppressedAt    DateTime @default(now())
  reason          String   @default("user_unsubscribe")
  sourceCampaign  String?
  // Stored so ops can re-validate the original click if a user disputes
  // an unsubscribe. `null` when the entry was written by a system path
  // (bounce/complaint/admin) rather than a user unsubscribe click.
  unsubscribeToken String?

  @@index([suppressedAt])
}

model ProcessedWebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  source    String   @default("stripe")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Referral {
  id            String    @id @default(cuid())
  referrerId    String
  referrer      User      @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredEmail String
  referredId    String?
  referred      User?     @relation("ReferredReferrals", fields: [referredId], references: [id])
  status        String    @default("PENDING") // PENDING | COMPLETED | EXPIRED
  rewardGranted Boolean   @default(false)
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([referrerId])
  @@index([referredEmail])
}
